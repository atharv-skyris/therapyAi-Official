<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Therapy AI - Notes</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Indie+Flower&family=Lora:ital,wght@0,400;0,700;1,400;1,700&family=Roboto:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/public/css/notes.css">
    <!-- Add DOMPurify for sanitization -->

</head>
<body>
    <div class="notes-container">
        <!-- Header with back button and new note input -->
        <div class="notes-header">
            <a href="/" class="back-btn" aria-label="Go back">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
            </a>
            <button class="theme-toggle" aria-label="Toggle dark/light theme">
                <svg class="sun-and-moon" aria-hidden="true" width="24" height="24" viewBox="0 0 24 24">
                    <mask class="moon" id="moon-mask">
                        <rect x="0" y="0" width="100%" height="100%" fill="white" />
                        <circle cx="24" cy="10" r="6" fill="black" />
                    </mask>
                    <circle class="sun" cx="12" cy="12" r="6" mask="url(#moon-mask)" fill="currentColor" />
                    <g class="sun-beams" stroke="currentColor">
                        <line x1="12" y1="1" x2="12" y2="3" />
                        <line x1="12" y1="21" x2="12" y2="23" />
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                        <line x1="1" y1="12" x2="3" y2="12" />
                        <line x1="21" y1="12" x2="23" y2="12" />
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                    </g>
                </svg>
            </button>
            <div class="new-note-input">
                <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 0 24 24" width="24px" fill="currentColor"><path d="M0 0h24v24H0V0z" fill="none"/><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                <input type="text" placeholder="Search notes..." id="newNoteInput">
            </div>
            <button id="font-toggle-btn" class="control-btn" title="Change Font" aria-label="Change note font">
                <svg class="font-icon icon-handwriting" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 0 24 24" width="24px" fill="currentColor"><path d="M12.4 3.2c-1 .2-2 .8-2.7 1.5-1.5 1.5-2.2 3.5-2.2 5.5 0 2.3.8 4.3 2.5 6 1.1 1.1 2.5 1.8 4 1.8 1 0 2-.3 2.8-.8.8-.6 1.2-1.4 1.2-2.3 0-.6-.1-1.1-.4-1.6-.3-.5-.7-.9-1.2-1.2-.5-.3-1-.5-1.5-.5-.4 0-.8.1-1.2.2-.3.2-.6.4-.9.7-.3.3-.5.7-.6 1-.2.4-.3.9-.3 1.4 0 .3.1.5.2.7.1.2.3.3.4.4.2.1.4.1.6.1s.4-.1.6-.2c.2-.1.3-.3.4-.4.1-.2.2-.4.2-.6h1.8c0 .8-.3 1.6-.8 2.2-.5.6-1.2 1-2.1 1.2s-1.8.3-2.8.3c-2 0-3.8-.7-5.2-2.1-1.4-1.4-2.1-3.3-2.1-5.6 0-2.3.8-4.4 2.3-6.1C8.8 4.5 10.4 3.6 12.2 3c.3-.1.5-.1.6-.1s.3 0 .4.1.2.1.3.2.1.2.1.3c0 .2 0 .3-.1.4s-.1.2-.3.3c-.1.1-.3.1-.4.1-.2 0-.3 0-.4-.1z"/></svg>
                <svg class="font-icon icon-serif" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 0 24 24" width="24px" fill="currentColor"><path d="M7 15h2l1-3h4l1 3h2L12 3 7 15zm3.6-5L12 5.8 13.4 10h-2.8z M5 17v2h14v-2H5z"></path></svg>
                <svg class="font-icon icon-sans" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 0 24 24" width="24px" fill="currentColor"><path d="M7 15h2l1-3h4l1 3h2L12 3 7 15zm3.6-5L12 5.8 13.4 10h-2.8z"></path></svg>
            </button>
            <button id="add-note-btn" class="add-note-btn" aria-label="Add new note">+</button>
        </div>

        <!-- Notes grid -->
        <div class="notes-grid">
            <!-- Note cards will be dynamically added here -->
            <div class="note-card">
                <p>Your therapy session notes will appear here...</p>
                <span class="note-date">Today</span>
            </div>
            <div class="note-card">
                <p>Click + to add a new note</p>
                <span class="note-date">Yesterday</span>
            </div>
            <div class="note-card">
                <p>Each card represents a session...</p>
                <span class="note-date">2 days ago</span>
            </div>
            <div class="note-card">
                <p>Keep track of your progress...</p>
                <span class="note-date">3 days ago</span>
            </div>
        </div>
    </div>

    <!-- Note Creation Modal -->
    <div class="note-modal" id="noteModal">
        <div class="note-modal-content">
            <div class="note-modal-header">
                <input type="text" id="noteTitleInput" placeholder="Title" class="note-title-input">
                <div class="note-modal-controls">
                    <button class="close-modal-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" height="24" viewBox="0 0 24 24" width="24" fill="currentColor">
                            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z"/>
                        </svg>
                    </button>
                </div>
            </div>
            <div class="note-editor-container">
                <textarea id="noteDescriptionInput" placeholder="Take a note..." class="note-description-input"></textarea>
            </div>
            <div class="note-modal-footer">
                <button class="save-note-btn">Save</button>
            </div>
        </div>
    </div>

    <!-- Modal Backdrop -->
    <div class="modal-backdrop" id="modalBackdrop"></div>
    <div id="notification-container"></div>

    <script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.6/dist/purify.min.js"></script>
    <script src="/public/js/notes.js" defer></script>
</body>
</html>
