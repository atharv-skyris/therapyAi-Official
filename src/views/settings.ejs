<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings - Therapy AI</title>
    <link rel="stylesheet" href="/public/css/settings.css">
    <script src="/public/js/settings.js" defer></script>
</head>
<body>
    <div class="settings-container">
        <header class="settings-header">
            <a href="/" class="back-btn" aria-label="Go back to main page">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 12H5M12 19l-7-7 7-7" />
                </svg>
            </a>
            <h1>Settings</h1>
        </header>

        <main class="settings-content">
            <!-- Appearance Section -->
            <section class="settings-section" aria-labelledby="appearance-heading">
                <h2 id="appearance-heading">Appearance</h2>
                <div class="setting-item">
                    <label for="theme-selector">Theme</label>
                    <div class="theme-switcher">
                        <button class="theme-option" data-theme="light">Light</button>
                        <button class="theme-option active" data-theme="dark">Dark</button>
                    </div>
                </div>
            </section>

            <!-- Data Management Section -->
            <section class="settings-section" aria-labelledby="data-heading">
                <h2 id="data-heading">Data Management</h2>
                <div class="setting-item">
                    <label>Export Notes</label>
                    <button id="export-btn" class="action-btn">Export as JSON</button>
                </div>
                <div class="setting-item">
                    <label for="import-file">Import Notes</label>
                    <input type="file" id="import-file" accept=".json" style="display: none;">
                    <button id="import-btn" class="action-btn">Import from JSON</button>
                </div>
                <div class="setting-item danger-zone">
                    <label>Delete Data</label>
                    <button id="delete-all-btn" class="action-btn danger-btn">Delete All Notes</button>
                </div>
            </section>
            
            <!-- About Section -->
            <section class="settings-section" aria-labelledby="about-heading">
                <h2 id="about-heading">About</h2>
                <div class="about-content">
                    <p><strong>Therapy AI</strong> - Version 1.0</p>
                    <p>Your private and secure space for reflection.</p>
                    <p>Created with ❤️</p>
                </div>
            </section>
        </main>
    </div>

    <!-- Confirmation Modal -->
    <div id="confirmation-modal" class="modal-overlay hidden">
        <div class="modal-content">
            <h2 id="modal-title">Are you sure?</h2>
            <p id="modal-message">This action cannot be undone.</p>
            <div class="modal-actions">
                <button id="confirm-btn" class="danger-btn">Confirm</button>
                <button id="cancel-btn">Cancel</button>
            </div>
        </div>
    </div>
    <div id="notification-container"></div>
</body>
</html> 