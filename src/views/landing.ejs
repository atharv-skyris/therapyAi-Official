<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Therapy AI - Your AI companion for mental wellness.">
    <title>Therapy AI - Welcome</title>
    <link rel="stylesheet" href="/public/css/landing.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <header class="site-header">
        <div class="container">
            <nav class="main-nav">
                <div class="logo">Therapy AI</div>
                <ul class="nav-links">
                    <li><a href="#features">Features</a></li>
                    <li><a href="#how-it-works">How It Works</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        <section class="hero">
            <div class="container">
                <div class="hero-content">
                    <h1 class="hero-title">Find Your Clarity.</h1>
                    <p class="hero-subtitle">Your private, AI-powered companion for navigating thoughts and emotions. Always here, always secure.</p>
                    <a href="index.ejs" class="cta-button">Launch App</a>
                </div>
            </div>
        </section>

        <section id="features" class="features-section">
            <div class="container">
                <h2 class="section-title">Features Designed for You</h2>
                <div class="feature-cards">
                    <div class="card">
                        <h3>AI Conversations</h3>
                        <p>Engage in meaningful conversations with our advanced AI, trained to listen and help you reflect.</p>
                    </div>
                    <div class="card">
                        <h3>Private Journal</h3>
                        <p>Keep a secure digital journal to track your thoughts, feelings, and progress over time.</p>
                    </div>
                    <div class="card">
                        <h3>Insightful Summaries</h3>
                        <p>Get AI-powered summaries of your journal entries to discover patterns and gain clarity.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="how-it-works" class="how-it-works-section">
            <div class="container">
                <h2 class="section-title">A Simple Path to Wellness</h2>
                <div class="steps">
                    <div class="step">
                        <div class="step-number">1</div>
                        <h3>Launch the App</h3>
                        <p>No sign-up required. Just open the app to begin your session instantly.</p>
                    </div>
                    <div class="step">
                        <div class="step-number">2</div>
                        <h3>Talk or Write</h3>
                        <p>Interact with the AI or express yourself in your private journal.</p>
                    </div>
                    <div class="step">
                        <div class="step-number">3</div>
                        <h3>Gain Insights</h3>
                        <p>Use AI summaries to better understand your mental landscape.</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="site-footer">
        <div class="container">
            <p>&copy; 2024 Therapy AI. All Rights Reserved.</p>
        </div>
    </footer>

    <script src="/public/js/landing.js"></script>
